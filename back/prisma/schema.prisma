// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  standard
  admin
}

enum MediaType {
  film
  series
}

enum MediaStatus {
  draft
  published
  archived
}

enum SuggestionStatus {
  pending
  accepted
  refused
  processed
}

enum NotificationType {
  suggestion_accepted
  suggestion_refused
  suggestion_processed
  new_episode
}

model User {
  id             String    @id @default(uuid())
  username       String    @unique
  email          String    @unique
  firstName      String?
  lastName       String?
  avatarUrl      String?
  isLikesPrivate Boolean   @default(false)
  passwordHash   String    @map("password")
  role           UserRole  @default(standard)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  sessions         Session[]
  favorites        Favorite[]
  watchlist        WatchlistItem[]
  ratings          Rating[]
  playbackProgress PlaybackProgress[]
  suggestions      Suggestion[]
  notifications    Notification[]
  episodeProgress  EpisodePlaybackProgress[]
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  tokenHash  String   @unique
  userAgent  String?
  ipAddress  String?
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Media {
  id              String      @id @default(uuid())
  catalogIndex    Int         @unique @default(autoincrement())
  slug            String      @unique
  title           String
  synopsis        String
  type            MediaType   @default(film)
  status          MediaStatus @default(published)
  releaseYear     Int?
  durationMinutes Int?
  videoPath       String?
  posterPath      String?
  backdropPath    String?
  seriesDirPath   String?
  filmDirPath     String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  genres           Genre[]
  favorites        Favorite[]
  watchlist        WatchlistItem[]
  ratings          Rating[]
  playbackProgress PlaybackProgress[]
  suggestions      Suggestion[]
  serie            Serie?

  @@index([type, status, catalogIndex])
}

model Genre {
  id        String   @id @default(uuid())
  name      String   @unique
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  medias    Media[]
}

model Favorite {
  id        String   @id @default(uuid())
  userId    String
  mediaId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@index([userId])
}

model WatchlistItem {
  id        String   @id @default(uuid())
  userId    String
  mediaId   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@index([userId])
}

model Rating {
  id        String   @id @default(uuid())
  userId    String
  mediaId   String
  value     Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@index([userId])
}

model PlaybackProgress {
  id              String   @id @default(uuid())
  userId          String
  mediaId         String
  positionSeconds Float    @default(0)
  durationSeconds Float?
  completed       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  media           Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([userId, mediaId])
  @@index([userId])
}

model Suggestion {
  id        String           @id @default(uuid())
  userId    String
  title     String
  synopsis  String?
  adminNote String?
  status    SuggestionStatus @default(pending)
  mediaId   String?
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  media     Media?           @relation(fields: [mediaId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
}

model Serie {
  id        String   @id @default(uuid())
  mediaId   String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  media     Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  seasons   Season[]
}

model Season {
  id        String    @id @default(uuid())
  serieId   String
  number    Int
  title     String?
  synopsis  String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  serie     Serie     @relation(fields: [serieId], references: [id], onDelete: Cascade)
  episodes  Episode[]

  @@unique([serieId, number])
  @@index([serieId])
}

model Episode {
  id              String                    @id @default(uuid())
  seasonId        String
  number          Int
  title           String
  synopsis        String?
  durationMinutes Int?
  videoPath       String?
  status          MediaStatus               @default(published)
  createdAt       DateTime                  @default(now())
  updatedAt       DateTime                  @updatedAt
  season          Season                    @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  playbackProgress EpisodePlaybackProgress[]

  @@unique([seasonId, number])
  @@index([seasonId])
}

model EpisodePlaybackProgress {
  id              String   @id @default(uuid())
  userId          String
  episodeId       String
  positionSeconds Float    @default(0)
  durationSeconds Float?
  completed       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  episode         Episode  @relation(fields: [episodeId], references: [id], onDelete: Cascade)

  @@unique([userId, episodeId])
  @@index([userId])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String?
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
}
